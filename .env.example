# OpenDirectory Environment Configuration
# Copy this file to .env and update with your values
#
# IMPORTANT: All passwords and secrets MUST be changed before deployment!
# Generate secure passwords with: openssl rand -base64 32

# ===================
# Environment
# ===================
NODE_ENV=development
LOG_LEVEL=info

# ===================
# Database Configuration
# Generate each with: openssl rand -base64 32
# ===================
DB_PASSWORD=
MONGO_PASSWORD=
REDIS_PASSWORD=
RABBITMQ_PASSWORD=

# ===================
# LDAP Configuration
# Generate with: openssl rand -base64 64
# ===================
LLDAP_JWT_SECRET=
LLDAP_ADMIN_PASSWORD=

# ===================
# Security
# JWT_SECRET: Generate with: openssl rand -base64 64
# ENCRYPTION_KEY: Must be exactly 32 characters: openssl rand -hex 16
# ===================
JWT_SECRET=
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_EXPIRES_IN=7d
ENCRYPTION_KEY=

# ===================
# API Gateway Admin Credentials
# Used for Basic Auth on the API gateway
# ===================
ADMIN_USERNAME=
ADMIN_PASSWORD=

# ===================
# SSH Configuration
# Used for remote device management (prefer SSH keys in production)
# ===================
SSH_PASSWORD=

# CT2001 Device Connection
CT2001_HOST=192.168.1.51
CT2001_USERNAME=root
CT2001_PASSWORD=
CT2001_PORT=22

# ===================
# Service URLs
# ===================
API_GATEWAY_URL=http://localhost:3000
API_BACKEND_URL=http://localhost:8080
AUTH_SERVICE_URL=http://localhost:3002
IDENTITY_SERVICE_URL=http://localhost:3001
DEVICE_SERVICE_URL=http://localhost:3003
POLICY_SERVICE_URL=http://localhost:3004

# ===================
# Frontend Configuration
# ===================
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080

# ===================
# Email Configuration (Optional)
# ===================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=OpenDirectory <notifications@example.com>

# ===================
# Storage Configuration (Optional)
# Generate credentials with: openssl rand -base64 24
# ===================
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=opendirectory

# ===================
# CORS & Security
# ===================
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ===================
# Monitoring (Optional)
# ===================
GRAFANA_PASSWORD=
PROMETHEUS_ENABLED=true
METRICS_PORT=9091

# ===================
# Feature Flags
# ===================
FEATURE_MDM_ENABLED=true
FEATURE_CONDITIONAL_ACCESS_ENABLED=true
FEATURE_CERTIFICATE_MANAGEMENT_ENABLED=true
FEATURE_UPDATE_MANAGEMENT_ENABLED=true
FEATURE_PRINT_MANAGEMENT_ENABLED=true
FEATURE_LICENSE_MANAGEMENT_ENABLED=true
