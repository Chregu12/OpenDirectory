{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Connected Agents",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "opendirectory_connected_agents",
          "legendFormat": "Agents"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 5 }
            ]
          },
          "max": 100,
          "unit": "short"
        }
      }
    },
    {
      "id": 2,
      "title": "Active Devices",
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 0 },
      "targets": [
        {
          "expr": "opendirectory_active_devices_total",
          "legendFormat": "Active"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Compliance Score",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 4, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "opendirectory_compliance_ratio * 100",
          "legendFormat": "Compliance %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 70 },
              { "color": "green", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Active Threats",
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "opendirectory_active_threats",
          "legendFormat": "Threats"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Backup Status",
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "time() - opendirectory_backup_last_success_timestamp",
          "legendFormat": "Last Backup"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 43200 },
              { "color": "red", "value": 86400 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Update Compliance",
      "type": "piechart",
      "gridPos": { "h": 6, "w": 4, "x": 20, "y": 0 },
      "targets": [
        {
          "expr": "opendirectory_update_compliance_ratio * 100",
          "legendFormat": "Compliant"
        },
        {
          "expr": "(1 - opendirectory_update_compliance_ratio) * 100",
          "legendFormat": "Non-Compliant"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      }
    },
    {
      "id": 7,
      "title": "Agent Command Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "rate(opendirectory_agent_commands_total[5m])",
          "legendFormat": "Commands/s ({{ job }})"
        },
        {
          "expr": "rate(opendirectory_agent_command_failures_total[5m])",
          "legendFormat": "Failures/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Policy Deployments / Hour",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "increase(opendirectory_policy_deployments_total[1h])",
          "legendFormat": "Deployments"
        },
        {
          "expr": "increase(opendirectory_policy_deploy_failures_total[1h])",
          "legendFormat": "Failures"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 9,
      "title": "Service Latency (P99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "http_request_duration_seconds{quantile=\"0.99\"}",
          "legendFormat": "{{ job }} P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5,
            "showPoints": "never"
          }
        }
      }
    },
    {
      "id": 10,
      "title": "Threat Score Timeline",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "expr": "opendirectory_threat_score",
          "legendFormat": "Threat Score"
        },
        {
          "expr": "opendirectory_anomaly_count",
          "legendFormat": "Anomalies"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "showPoints": "never"
          },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 0.8 }
            ]
          }
        }
      }
    },
    {
      "id": 11,
      "title": "Certificate Expiry",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "targets": [
        {
          "expr": "opendirectory_cert_days_until_expiry < 90",
          "legendFormat": "{{ common_name }}",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": 0 },
                    { "color": "yellow", "value": 14 },
                    { "color": "green", "value": 60 }
                  ]
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 12,
      "title": "Replication Lag",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "targets": [
        {
          "expr": "opendirectory_replication_lag_seconds",
          "legendFormat": "{{ region }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 30 },
              { "color": "red", "value": 60 }
            ]
          }
        }
      }
    }
  ],
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["opendirectory", "overview"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "",
  "title": "OpenDirectory Overview",
  "uid": "opendirectory-overview",
  "version": 1
}
