{
  "id": "tpl-password-policy",
  "name": "Cross-Platform Password Policy",
  "description": "Standard enterprise password requirements applicable to Windows, macOS, and Linux. Enforces minimum length, complexity, history, aging, and account lockout.",
  "type": "password",
  "platform": "all",
  "version": "1.0.0",
  "settings": {
    "password": {
      "minLength": 12,
      "maxAge": 90,
      "minAge": 1,
      "history": 24,
      "complexity": true,
      "requireDigit": true,
      "requireUppercase": true,
      "requireLowercase": true,
      "requireSymbol": true,
      "maxRepeat": 3,
      "dictionaryCheck": true,
      "warnAge": 14
    },
    "lockout": {
      "threshold": 5,
      "duration": 30,
      "window": 30
    },
    "screenLock": {
      "timeout": 15
    }
  }
}
