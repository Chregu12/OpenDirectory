{
  "name": "@opendirectory/auto-remediation",
  "version": "1.0.0",
  "description": "OpenDirectory Auto Remediation Engine - Detects compliance issues and generates platform-specific remediation scripts",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "docker:build": "docker build -t opendirectory/auto-remediation .",
    "docker:run": "docker run -p 3021:3021 opendirectory/auto-remediation",
    "health-check": "curl -f http://localhost:3021/health || exit 1"
  },
  "keywords": [
    "opendirectory",
    "auto-remediation",
    "compliance",
    "script-generation",
    "playbooks",
    "security",
    "endpoint-management",
    "enterprise"
  ],
  "author": "OpenDirectory Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/opendirectory/services.git",
    "directory": "services/enterprise/auto-remediation"
  },
  "bugs": {
    "url": "https://github.com/opendirectory/services/issues"
  },
  "homepage": "https://github.com/opendirectory/services/tree/main/services/enterprise/auto-remediation#readme",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^6.8.1",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.1",
    "uuid": "^9.0.0",
    "winston": "^3.10.0",
    "winston-daily-rotate-file": "^4.7.1",
    "node-cron": "^3.0.2",
    "axios": "^1.4.0",
    "lodash": "^4.17.21",
    "moment": "^2.29.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.6.1",
    "supertest": "^6.3.3",
    "eslint": "^8.44.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-n": "^16.0.1",
    "eslint-plugin-promise": "^6.1.1"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
